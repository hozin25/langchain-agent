# Copy this file to `.env` and fill in your keys.
# The agent reads these at launch (loaded via dotenv in the main process).

# --- GLM (智谱) — required, used by default ---
# Get your key at https://open.bigmodel.cn/
GLM_API_KEY=xxxxxxxx.xxxxxxxxxxxxxxxx
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- DeepSeek — required for deepseek-* models ---
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Deprecated providers (kept for reference; not wired into the UI) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# DEFAULT_PROVIDER=anthropic
# DEFAULT_MODEL=claude-sonnet-4-6

# --- Tavily — required for web_search tool ---
# Get your key at https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxx
